# =============================================================================
# NES Playground - generated by the Play-in-NES button
# =============================================================================
# The pupil doesn't edit anything in this folder directly — the playground
# server writes src/scene.inc, src/palettes.inc, assets/sprites/game.chr and
# assets/backgrounds/level.nam from whatever they built in the editor, then
# invokes `make run` here.

CC      = cc65
AS      = ca65
LD      = ld65
TARGET  = nes
CONFIG  = cfg/nes.cfg
NESLIB  = /usr/share/cc65/lib/nes.lib

EMULATOR = fceux

ROM     = game.nes
BUILD   = build

C_SRC   = src/main.c
ASM_SRC = src/graphics.s

C_OBJ   = $(patsubst src/%.c,$(BUILD)/%.o,$(C_SRC))
ASM_OBJ = $(patsubst src/%.s,$(BUILD)/%.o,$(ASM_SRC))
OBJECTS = $(C_OBJ) $(ASM_OBJ)

.PHONY: all clean run

all: $(ROM)

$(BUILD):
	mkdir -p $(BUILD)

$(ROM): $(OBJECTS)
	$(LD) -C $(CONFIG) -o $@ $(OBJECTS) $(NESLIB)

# main.c depends on the generated includes so make re-runs when they change.
$(BUILD)/main.o: src/main.c src/scene.inc src/palettes.inc | $(BUILD)
	$(CC) -t $(TARGET) -o $(BUILD)/main.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/main.s
	rm -f $(BUILD)/main.s

$(BUILD)/%.o: src/%.s assets/sprites/game.chr assets/backgrounds/level.nam | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

run: $(ROM)
	$(EMULATOR) $(ROM)

clean:
	rm -rf $(BUILD) $(ROM)
