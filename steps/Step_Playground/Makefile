# =============================================================================
# NES Playground - generated by the Play-in-NES button
# =============================================================================
# The pupil doesn't edit anything in this folder directly — the playground
# server writes src/scene.inc, src/palettes.inc, assets/sprites/game.chr and
# assets/backgrounds/level.nam from whatever they built in the editor, then
# invokes `make run` here.

CC      = cc65
AS      = ca65
LD      = ld65
TARGET  = nes
CONFIG  = cfg/nes.cfg
NESLIB  = /usr/share/cc65/lib/nes.lib

# Why no `-O`: cc65 with optimisation enabled makes different
# inline / register decisions for the stock main.c vs the Builder's
# platformer.c template — the two files are semantically equivalent
# on the no-modules path but differ structurally (extra macros,
# `//@ insert:` slots, conditionally-gated globals).  Without -O
# both compile to literally identical bytes; with -O they diverge
# and the byte-identical-ROM invariant fires.  Targeted hotspots
# (the scroll column / row bursts) are unrolled manually in
# scroll.c so they get the cycle budget they need without giving
# up the invariant.
CFLAGS  =

EMULATOR = fceux

ROM     = game.nes
BUILD   = build

# Audio (Phase 4.3) — opt-in.  When USE_AUDIO=1 is passed on the
# make command line (the playground server sets it when the audio
# module is enabled), the FamiStudio sound engine + the per-project
# audio_songs.s + audio_sfx.s blobs get compiled in.  Default off
# keeps the 1×1 byte-identical baseline test honest.
USE_AUDIO ?= 0

C_SRC   = src/main.c src/behaviour.c src/bg_world.c src/scroll.c
ASM_SRC = src/graphics.s

FAMISTUDIO_DIR = ../../tools/audio/famistudio

ifeq ($(USE_AUDIO),1)
# audio_songs.s + audio_sfx.s are written into src/ by the
# playground server right before invoking make.  The engine itself
# lives outside the step tree and is referenced by relative path so
# we never accidentally ship a stale local copy.
AUDIO_OBJS = $(BUILD)/famistudio_crt0.o $(BUILD)/famistudio_engine.o $(BUILD)/audio_songs.o $(BUILD)/audio_sfx.o
CFLAGS    += -DUSE_AUDIO=1
endif

C_OBJ   = $(patsubst src/%.c,$(BUILD)/%.o,$(C_SRC))
ASM_OBJ = $(patsubst src/%.s,$(BUILD)/%.o,$(ASM_SRC))
OBJECTS = $(C_OBJ) $(ASM_OBJ) $(AUDIO_OBJS)

.PHONY: all clean run rebuild-run

all: $(ROM)

$(BUILD):
	mkdir -p $(BUILD)

$(ROM): $(OBJECTS)
	$(LD) -C $(CONFIG) -o $@ $(OBJECTS) $(NESLIB)

# main.c depends on the generated includes so make re-runs when they change.
# collision.h is generated by playground_server.py from the Behaviour page;
# listing it here makes main.o rebuild whenever the pupil repaints tiles.
$(BUILD)/main.o: src/main.c src/scene.inc src/palettes.inc src/collision.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/main.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/main.s
	rm -f $(BUILD)/main.s

# behaviour.c is auto-generated too. Keep it on the same collision.h dep so
# a behaviour-map edit rebuilds both objects.
$(BUILD)/behaviour.o: src/behaviour.c src/collision.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/behaviour.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/behaviour.s
	rm -f $(BUILD)/behaviour.s

# bg_world.c is the full-world nametable (Sprint 11 S-1).  Nothing in main.c
# references it yet, but it is compiled unconditionally so the scroll core
# sprints can assume the symbols are always linkable.  Depends on the
# generated header so a Backgrounds-page edit rebuilds it.
$(BUILD)/bg_world.o: src/bg_world.c src/bg_world.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/bg_world.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/bg_world.s
	rm -f $(BUILD)/bg_world.s

# scroll.c is the shared camera / PPU-scroll core (Sprint 11 S-1).  Like
# bg_world.c, slice 2 builds it in but main.c does not call it yet;
# slice 3 rewires main.c to follow the camera + stream columns.
$(BUILD)/scroll.o: src/scroll.c src/scroll.h src/bg_world.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/scroll.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/scroll.s
	rm -f $(BUILD)/scroll.s

$(BUILD)/%.o: src/%.s assets/sprites/game.chr assets/backgrounds/level.nam | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

# Audio (Phase 4.3) — only built when USE_AUDIO=1.  Engine asm is
# vendored under tools/audio/famistudio/ (see NOTICE.md there); we
# assemble the wrapper, which `.include`s the engine source so the
# vendored file stays untouched and our config flags (SFX_SUPPORT,
# DPCM_SUPPORT off, etc.) take effect.  The pupil-uploaded song /
# sfx blobs are staged into src/ by the playground server before
# each build.
$(BUILD)/famistudio_engine.o: $(FAMISTUDIO_DIR)/famistudio_engine.s $(FAMISTUDIO_DIR)/famistudio_ca65.s | $(BUILD)
	$(AS) -t $(TARGET) -I $(FAMISTUDIO_DIR) -o $@ $<

# Custom crt0 (Phase 4.3 follow-up).  cc65's stock crt0 supplies the
# VECTORS segment with NO project-level NMI hook, so we replace it
# with our own copy that adds `jsr _famistudio_update` to the NMI
# handler.  Listing this object first in the link line means ld65
# sees its `__STARTUP__` / `_exit` exports before searching nes.lib,
# so it never pulls cc65's crt0 in — preventing a double-vectors
# overflow.  Only built when USE_AUDIO=1; the no-audio build still
# uses cc65's stock crt0 exactly as before, keeping the byte-
# identical baseline test honest.  See famistudio_crt0.s for the
# full reasoning.
$(BUILD)/famistudio_crt0.o: $(FAMISTUDIO_DIR)/famistudio_crt0.s | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

$(BUILD)/audio_songs.o: src/audio_songs.s | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

$(BUILD)/audio_sfx.o: src/audio_sfx.s | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

run: $(ROM)
	$(EMULATOR) $(ROM)

# Safety belt: clean first, then build and run.
rebuild-run: clean run

clean:
	rm -rf $(BUILD) $(ROM)
