# NES Game Playground server — configuration template.
#
# Copy this file to `.env` (same folder) and edit the values you need:
#     cp .env.example .env
#
# `.env` is gitignored (it holds your class join code + admin secret).  The
# server loads it on startup via playground_server.py's _load_dotenv().  A real
# environment variable always overrides the file, so a systemd unit or a manual
# `VAR=… python3 …` launch still wins.  Restart the server after editing.
#
# Everything here is OPTIONAL — with no .env at all the server runs on its
# defaults (localhost:8765, accounts present but self-signup CLOSED).

# --- Network -------------------------------------------------------------
# 127.0.0.1 = this machine only (default).  Set 0.0.0.0 to let pupils on the
# LAN reach it (e.g. inside the classroom LXC).
#PLAYGROUND_HOST=127.0.0.1
#PLAYGROUND_PORT=8765

# --- Pupil accounts (all optional) --------------------------------------
# Self-signup is gated on a class join code: with NO code set, "Create account"
# is closed (signupsOpen=false) and the editor's account panel only offers
# sign-in.  Set a code your class will type to open enrolment.
#PLAYGROUND_JOIN_CODE=change-me-class-code

# Lets a teacher reset a pupil's forgotten password without their recovery code
# (POST /auth/admin/reset).  Leave empty to disable admin resets entirely.
# Generate a strong one, e.g.:  python3 -c "import secrets;print(secrets.token_urlsafe(24))"
#PLAYGROUND_ADMIN_SECRET=

# Session lifetime in seconds (0 = built-in default, ~30 days).
#PLAYGROUND_SESSION_TTL=0

# Where the SQLite accounts DB lives (default: tools/accounts.db).  Usually
# leave unset.  Do NOT point this at a test path on a dev machine.
#PLAYGROUND_ACCOUNTS_DB=tools/accounts.db

# Force the session cookie's Secure flag even over plain HTTP.  Set to 1 only
# behind an HTTPS reverse proxy that doesn't pass X-Forwarded-Proto.
#PLAYGROUND_FORCE_SECURE_COOKIES=0

# --- Auth rate limiting (per IP) ----------------------------------------
#PLAYGROUND_AUTH_RATE_MAX=12
#PLAYGROUND_AUTH_RATE_WINDOW=60
