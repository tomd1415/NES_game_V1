; project.inc — per-project ASM constants.
;
; Generated by tools/playground_server.py from the pupil's project (like
; scene.inc / collision.h). This checked-in copy matches the stock fixture so a
; DIRECT `make NES_ASM_*` build assembles; the server overwrites it per /play.
;
; The hand-written 6502 modules `.include "project.inc"` and reference these
; symbols so ONE fixed .s serves any project — ca65 bakes the right values at
; assemble time. See docs/plans/current/2026-07-06-asm-engine-generator.md.
;
; These use `.define` (textual, scope-independent) rather than `SYM = value`:
; ca65 does not resolve an `=` constant as a *constant expression* for `.if` /
; MULC inside a `.proc` scope, but a `.define` expands to the literal everywhere.

; --- World / collision map (behaviour_at) ---
.define WORLD_COLS             64     ; always a multiple of 32 (SCREEN_COLS * screens)
.define WORLD_ROWS             30
; --- Full-world background (scroll_stream_prepare / streamers) ---
.define BG_WORLD_COLS          64
.define BG_WORLD_ROWS          30
.define BG_WORLD_ATTR_COLS     16
; Rows the column streamer skips at the top (SMB bg status bar, sprite-0 split).
; 0 in the stock baseline = feature off = byte-identical; the server overrides
; this to 4 when the SMB background HUD is enabled.  Defined here so a direct
; `make NES_ASM_SCROLL=1` build (no server codegen) still assembles scroll_asm.s.
.define SCROLL_SKIP_TOP        0
; 1 when a wide (>8-screen) world's tiles are column-deduplicated (feedback #10)
; so the scroll core reads bg_col_index/bg_col_data; 0 in the stock baseline =
; raw bg_world_tiles = byte-identical.  Defined here so a direct
; `make NES_ASM_SCROLL=1` build assembles scroll_asm.s.
.define SCROLL_COMPRESSED      0
; --- Player (advance_animation) ---
.define PLAYER_W               2
.define PLAYER_H               2
.define PLAYER_TILES_PER_FRAME 4      ; PLAYER_W * PLAYER_H
; Tunable platformer physics (Style tab: Jump height / Jump speed / Gravity).
; Defaults 20 / 2 / 2 match the historic hardcoded values so a direct
; `make NES_ASM_PLAYER=1` build assembles byte-identically; the server overrides
; them per /play from the player + Globals config.  The ASM player reads these
; as immediates (`lda #JUMP_BUDGET` etc.) so the default ROM is unchanged.
.define JUMP_BUDGET           20      ; jmp_up frames on take-off (= Jump height)
.define JUMP_SPEED            2       ; pixels risen per frame (= Jump speed)
.define PLAYER_GRAVITY        2       ; pixels the player falls per frame (= Gravity)
; --- Scene sprites (reaction_for bound) ---
.define NUM_BEHAVIOUR_SPRITES  2
.define NUM_STATIC_SPRITES     1
; SS_POS_WIDE=1 when any scene sprite sits past the first screen (x or y > 255),
; so ss_x/ss_y are u16 (unsigned int) not u8 — the scene-draw ASM reads them at
; the right width. Matches build_scene_inc's `wide_pos`.
.define SS_POS_WIDE            0
; --- Fixed NES / engine constants (here so the modules need no other include) ---
.define SCREEN_W_PX            256
.define SCREEN_H_PX            240
