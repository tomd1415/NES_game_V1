# =============================================================================
# NES Playground - generated by the Play-in-NES button
# =============================================================================
# The pupil doesn't edit anything in this folder directly — the playground
# server writes src/scene.inc, src/palettes.inc, assets/sprites/game.chr and
# assets/backgrounds/level.nam from whatever they built in the editor, then
# invokes `make run` here.

CC      = cc65
AS      = ca65
LD      = ld65
TARGET  = nes
CONFIG  = cfg/nes.cfg
NESLIB  = /usr/share/cc65/lib/nes.lib

# Optimised build (`-Os`).  Arc D Sprint 4 (2026-06-20): the byte-identical
# invariant is golden-hash-based (tools/builder-tests/run-all.mjs), so -Os no
# longer trips a cross-file comparison — the goldens are pinned under -Os.
#
# A first -Os trial *looked* like it regressed two render tests, but tracing
# showed there is NO miscompilation: a scroll build streams its whole 2-screen
# world into VRAM over many vblanks before the main loop runs, and -Os finishes
# that load (and so the player's fall) ~45 frames sooner.  Both -O levels land
# the player correctly on the floor; the two tests were just sampling at a fixed
# frame count and catching the player mid-fall.  Those tests were made
# settle-to-rest, and -Os was enabled.  (FCEUX/Mesen A/B pass still recommended
# when changing this — the scroll bursts live on the NTSC vblank budget.)
# Revert: set `CFLAGS =` (empty) and restore the no-opt goldens
# (00e156fb… — kept in run-all.mjs's comment).
CFLAGS  = -Os

EMULATOR = fceux

ROM     = game.nes
BUILD   = build

# Audio (Phase 4.3) — opt-in.  When USE_AUDIO=1 is passed on the
# make command line (the playground server sets it when the audio
# module is enabled), the FamiStudio sound engine + the per-project
# audio_songs.s + audio_sfx.s blobs get compiled in.  Default off
# keeps the 1×1 byte-identical baseline test honest.
USE_AUDIO ?= 0

C_SRC   = src/main.c src/behaviour.c src/bg_world.c src/scroll.c
ASM_SRC = src/graphics.s

FAMISTUDIO_DIR = ../../tools/audio/famistudio

ifeq ($(USE_AUDIO),1)
# audio_songs.s + audio_sfx.s are written into src/ by the
# playground server right before invoking make.  The engine itself
# lives outside the step tree and is referenced by relative path so
# we never accidentally ship a stale local copy.
AUDIO_OBJS = $(BUILD)/famistudio_crt0.o $(BUILD)/famistudio_engine.o $(BUILD)/audio_songs.o $(BUILD)/audio_sfx.o
CFLAGS    += -DUSE_AUDIO=1
endif

# Event sound effects (engine v74) — opt-in, and only meaningful alongside
# USE_AUDIO (the server pairs the two).  When BW_SFX_EVENTS=1 is passed, main.c's
# per-frame edge-detectors trigger famistudio_sfx_play on jump / pickup / hurt /
# win.  Default off keeps every non-event-sound project byte-identical.
BW_SFX_EVENTS ?= 0
ifeq ($(BW_SFX_EVENTS),1)
CFLAGS    += -DBW_SFX_EVENTS=1
endif

# SMB background status bar (sprite-0 split): its PPU push runs from the NMI so
# the strip renders on time regardless of frame load (see src/hud_crt0.s +
# hud_present() in main.c).  HUD_NMI=1 (the playground server sets it when the
# bg status bar is enabled on a scroll build) links hud_crt0.o, which REPLACES
# whichever crt0 would otherwise link — cc65's stock crt0, or famistudio_crt0.o
# when audio is also on (famistudio_update keeps ticking from the main loop, so
# no audio coupling is lost).  Off by default -> non-HUD ROMs keep their existing
# crt0, byte-identical.
HUD_NMI ?= 0
ifeq ($(HUD_NMI),1)
AUDIO_OBJS := $(filter-out $(BUILD)/famistudio_crt0.o,$(AUDIO_OBJS))
HUD_OBJS = $(BUILD)/hud_crt0.o
endif

# Hand-written 6502 scroll helpers (asm-lab integration).  Off by default so the
# ROM is byte-identical to the pure-C engine.  NES_ASM_SCROLL=1 links
# src/scroll_asm.s (world_to_screen_x/y) and -D's out the matching C bodies in
# scroll.c, so exactly one definition of each symbol links.  Multi-screen builds
# only: the ASM references cam_x, which a 1x1 ROM's (empty) scroll.c never
# defines.  The ASM is proven equivalent to the C in asm-lab/.
NES_ASM_SCROLL ?= 0
ifeq ($(NES_ASM_SCROLL),1)
CFLAGS  += -DNES_ASM_SCROLL=1
ASM_SRC += src/scroll_asm.s
endif

# UNIVERSAL leaf helpers on hand-written 6502 (asm-lab).  Project-independent
# (bake only NES-fixed constants), so the server ships these for every build.
# Same off-by-default, byte-identical-when-off contract as NES_ASM_SCROLL.  Links
# main_asm.s (read_controller, write_palettes) and -D's out the matching C bodies.
NES_ASM_LEAF ?= 0
ifeq ($(NES_ASM_LEAF),1)
CFLAGS  += -DNES_ASM_LEAF=1
ASM_SRC += src/main_asm.s src/behaviour_asm.s
endif

# Dimension-SPECIALISED hand-written 6502 (asm-lab).  These bake this build's
# world/player dimensions (behaviour_at -> WORLD_COLS, scroll_stream_prepare ->
# BG_WORLD_COLS + horizontal-only, advance_animation -> PLAYER_TILES_PER_FRAME),
# so unlike NES_ASM_SCROLL / NES_ASM_LEAF they are NOT project-independent and the
# server never ships them — they're for direct/lab builds on a matching fixture.
# Requires NES_ASM_SCROLL (scroll_stream_prepare needs cam_x et al).  Same
# off-by-default, byte-identical-when-off contract.
NES_ASM_SPECIALIZED ?= 0
ifeq ($(NES_ASM_SPECIALIZED),1)
CFLAGS  += -DNES_ASM_SPECIALIZED=1
ASM_SRC += src/main_special_asm.s
endif

# Scene-sprite DRAW loop on hand-written 6502 (Phase 2a).  Generic: loops over
# NUM_STATIC_SPRITES reading the ss_* arrays (project.inc SS_POS_WIDE picks the
# u8/u16 position width) and calls world_to_screen_x/y — project-independent, so
# shippable.  Links src/scene_asm.s and -D's out the PLAIN C draw loop in main.c.
# Only valid when the project has no per-sprite tagged animations (the server
# enables it only for BW_HAS_SCENE_ANIM==0).  Same off-by-default, byte-identical
# -when-off contract.  Needs NES_ASM_SCROLL (calls world_to_screen_x/y).
NES_ASM_SCENE ?= 0
ifeq ($(NES_ASM_SCENE),1)
CFLAGS  += -DNES_ASM_SCENE=1
ASM_SRC += src/scene_asm.s
endif

# Player-1 OAM DRAW loop on hand-written 6502 (Phase 2d).  Generic: builds the
# P1 sprite's OAM entries each frame from anim_tiles/anim_attrs/anim_base (so it
# covers both the static player and any assigned animation) and calls
# world_to_screen_x/y — project-independent, so shippable.  Links
# src/pdraw_asm.s and -D's out the PLAIN C P1 draw loop in main.c (the C call
# site also excludes the bob case).  Needs NES_ASM_SCROLL (world_to_screen).
# Same off-by-default, byte-identical-when-off contract.
NES_ASM_PDRAW ?= 0
ifeq ($(NES_ASM_PDRAW),1)
CFLAGS  += -DNES_ASM_PDRAW=1
ASM_SRC += src/pdraw_asm.s
endif

# Scene-sprite AI helpers on hand-written 6502 (Phase 2b).  NES_ASM_AI=1 links
# src/ai_asm.s (bw_sprite_blocked — the per-enemy collision probe, calls the
# shipped behaviour_at) and -D's out the matching C helper emitted into main.c by
# builder-modules.js.  Needs NES_ASM_LEAF (behaviour_at).  Same off-by-default,
# byte-identical-when-off contract; not shipped to pupils yet (PLAYGROUND_ASM_AI).
NES_ASM_AI ?= 0
ifeq ($(NES_ASM_AI),1)
CFLAGS  += -DNES_ASM_AI=1
ASM_SRC += src/ai_asm.s
endif

# Player update on hand-written 6502 (Phase 2c).  NES_ASM_PLAYER=1 links
# src/player_asm.s (td_update — the top-down 4-way move+collision) and -D's out
# the matching C player block in main.c.  Requires a SCROLL build (px/py are u16)
# + top-down game style; needs NES_ASM_LEAF (behaviour_at).  Same off-by-default,
# byte-identical-when-off contract; not shipped to pupils yet (PLAYGROUND_ASM_PLAYER).
# SMB player update on hand-written 6502 (Phase 2c 5b).  NES_ASM_SMB=1 IMPLIES
# NES_ASM_PLAYER (so player_asm.s links + the C SMB blocks are -D'd out and
# smb_update() is called) AND passes `-D NES_ASM_SMB` to ca65 so player_asm.s
# compiles its SMB section (smb_update + the SMB-only globals _smb_vx/_smb_px_sub
# it imports).  Only valid for an SMB build (BW_GAME_STYLE 0 + BW_SMB_JUMP).  Same
# off-by-default, byte-identical-when-off contract; not shipped to pupils yet.
# Set before the NES_ASM_PLAYER block so the := takes effect there.
NES_ASM_SMB ?= 0
ifeq ($(NES_ASM_SMB),1)
NES_ASM_PLAYER := 1
ASFLAGS += -D NES_ASM_SMB
endif

# Racer player update on hand-written 6502 (Phase 2c).  NES_ASM_RACER=1 IMPLIES
# NES_ASM_PLAYER (links player_asm.s + -D's out the C style-3 P1 block + calls
# racer_update()) AND passes `-D NES_ASM_RACER` to ca65 so player_asm.s compiles its
# racer section (racer_update + the racer-only globals racer_heading/speed/px_sub/
# py_sub/cp_stage/laps/finished it imports).  Only valid for a racer build
# (BW_GAME_STYLE 3).  Same off-by-default, byte-identical-when-off contract.
# Set before the NES_ASM_PLAYER block so the := takes effect there.
NES_ASM_RACER ?= 0
ifeq ($(NES_ASM_RACER),1)
NES_ASM_PLAYER := 1
ASFLAGS += -D NES_ASM_RACER
endif

# Player-2 second-actor update on hand-written 6502 (Phase 2c).  NES_ASM_PLAYER2=1
# IMPLIES NES_ASM_PLAYER (links player_asm.s + -D's out the C P2 block + calls the
# p2_*_update proc) AND passes `-D NES_ASM_PLAYER2` to ca65 so player_asm.s compiles
# its P2 section (the p2_* procs + the P2-only globals px2/py2/pad2/... it imports).
# Only valid for a 2-player build (PLAYER2_ENABLED).  Same off-by-default,
# byte-identical-when-off contract.  Set before the NES_ASM_PLAYER block so the :=
# takes effect there.
NES_ASM_PLAYER2 ?= 0
ifeq ($(NES_ASM_PLAYER2),1)
NES_ASM_PLAYER := 1
ASFLAGS += -D NES_ASM_PLAYER2
endif

NES_ASM_PLAYER ?= 0
ifeq ($(NES_ASM_PLAYER),1)
CFLAGS  += -DNES_ASM_PLAYER=1
ASM_SRC += src/player_asm.s
endif

C_OBJ   = $(patsubst src/%.c,$(BUILD)/%.o,$(C_SRC))
ASM_OBJ = $(patsubst src/%.s,$(BUILD)/%.o,$(ASM_SRC))
OBJECTS = $(C_OBJ) $(ASM_OBJ) $(AUDIO_OBJS) $(HUD_OBJS)

.PHONY: all clean run rebuild-run

all: $(ROM)

$(BUILD):
	mkdir -p $(BUILD)

$(ROM): $(OBJECTS)
	$(LD) -C $(CONFIG) -o $@ $(OBJECTS) $(NESLIB)

# main.c depends on the generated includes so make re-runs when they change.
# collision.h is generated by playground_server.py from the Behaviour page;
# listing it here makes main.o rebuild whenever the pupil repaints tiles.
$(BUILD)/main.o: src/main.c src/scene.inc src/palettes.inc src/collision.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/main.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/main.s
	rm -f $(BUILD)/main.s

# behaviour.c is auto-generated too. Keep it on the same collision.h dep so
# a behaviour-map edit rebuilds both objects.
$(BUILD)/behaviour.o: src/behaviour.c src/collision.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/behaviour.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/behaviour.s
	rm -f $(BUILD)/behaviour.s

# bg_world.c is the full-world nametable (Sprint 11 S-1).  Nothing in main.c
# references it yet, but it is compiled unconditionally so the scroll core
# sprints can assume the symbols are always linkable.  Depends on the
# generated header so a Backgrounds-page edit rebuilds it.
$(BUILD)/bg_world.o: src/bg_world.c src/bg_world.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/bg_world.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/bg_world.s
	rm -f $(BUILD)/bg_world.s

# scroll.c is the shared camera / PPU-scroll core (Sprint 11 S-1).  Like
# bg_world.c, slice 2 builds it in but main.c does not call it yet;
# slice 3 rewires main.c to follow the camera + stream columns.
$(BUILD)/scroll.o: src/scroll.c src/scroll.h src/bg_world.h | $(BUILD)
	$(CC) -t $(TARGET) $(CFLAGS) -o $(BUILD)/scroll.s $<
	$(AS) -t $(TARGET) -o $@ $(BUILD)/scroll.s
	rm -f $(BUILD)/scroll.s

# -I src so the hand-written engine .s files can `.include "project.inc"` +
# "asm_macros.inc" (Phase 1: per-project ASM constants + the MULC macro).
$(BUILD)/%.o: src/%.s assets/sprites/game.chr assets/backgrounds/level.nam | $(BUILD)
	$(AS) -t $(TARGET) $(ASFLAGS) -I src -o $@ $<

# Audio (Phase 4.3) — only built when USE_AUDIO=1.  Engine asm is
# vendored under tools/audio/famistudio/ (see NOTICE.md there); we
# assemble the wrapper, which `.include`s the engine source so the
# vendored file stays untouched and our config flags (SFX_SUPPORT,
# DPCM_SUPPORT off, etc.) take effect.  The pupil-uploaded song /
# sfx blobs are staged into src/ by the playground server before
# each build.
$(BUILD)/famistudio_engine.o: $(FAMISTUDIO_DIR)/famistudio_engine.s $(FAMISTUDIO_DIR)/famistudio_ca65.s | $(BUILD)
	$(AS) -t $(TARGET) -I $(FAMISTUDIO_DIR) -o $@ $<

# Custom crt0 (Phase 4.3 follow-up).  cc65's stock crt0 supplies the
# VECTORS segment with NO project-level NMI hook, so we replace it
# with our own copy that adds `jsr _famistudio_update` to the NMI
# handler.  Listing this object first in the link line means ld65
# sees its `__STARTUP__` / `_exit` exports before searching nes.lib,
# so it never pulls cc65's crt0 in — preventing a double-vectors
# overflow.  Only built when USE_AUDIO=1; the no-audio build still
# uses cc65's stock crt0 exactly as before, keeping the byte-
# identical baseline test honest.  See famistudio_crt0.s for the
# full reasoning.
$(BUILD)/famistudio_crt0.o: $(FAMISTUDIO_DIR)/famistudio_crt0.s | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

$(BUILD)/audio_songs.o: src/audio_songs.s | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

$(BUILD)/audio_sfx.o: src/audio_sfx.s | $(BUILD)
	$(AS) -t $(TARGET) -o $@ $<

run: $(ROM)
	$(EMULATOR) $(ROM)

# Safety belt: clean first, then build and run.
rebuild-run: clean run

clean:
	rm -rf $(BUILD) $(ROM)
