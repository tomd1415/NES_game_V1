# Build artifacts
build/
*.nes
level.nam
game.chr
scene.inc
palettes.inc
*.bak

# Runtime gallery entries — pupil publishes land here; the playground
# server creates the dir at startup (GALLERY_DIR.mkdir). Never commit them.
tools/gallery/

# Step_Playground engine files the playground server regenerates on every
# build (write_text/write_bytes into the tracked source tree — see
# playground_server.py build_shared). Keeping them tracked made every local
# playtest/test dirty the repo. game.chr/level.nam are covered by the generic
# rules above; these four need explicit paths because the names are generic.
steps/Step_Playground/src/collision.h
steps/Step_Playground/src/behaviour.c
steps/Step_Playground/src/bg_world.h
steps/Step_Playground/src/bg_world.c

# Pupil starter assets generated from assets/pupil/my_tiles.txt — regenerable,
# so not tracked (keep my_tiles.txt, the source):
#   my_project.json       <- python3 tools/convert_my_tiles.py
#   palette_reference.png  <- python3 tools/generate_palette_reference.py
#   preview.png            <- python3 tools/tile_editor.py my_tiles.txt --watch
assets/pupil/my_project.json
assets/pupil/palette_reference.png
assets/pupil/preview.png

# Pupil feedback log + handled-set (local teacher state)
feedback.jsonl
feedback-handled.json

# Pupil accounts DB (T4.2) — holds usernames + password hashes; never commit.
tools/accounts.db
tools/accounts.db-*
accounts.db
accounts.db-*

# Local server config (PLAYGROUND_* — class join code, admin secret, port…).
# Loaded by playground_server.py at startup; the committed template is
# .env.example.  Never commit the real .env.
.env
.env.*
!.env.example

# Python bytecode cache
__pycache__/
*.pyc
